local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local screenGui = Instance.new("ScreenGui", playerGui)
screenGui.IgnoreGuiInset = true
screenGui.ResetOnSpawn = false

-- Outer RGB glow layer (sits behind the mouse body, bigger + blurred via image)
local glowLayer = Instance.new("ImageLabel", screenGui)
glowLayer.Size = UDim2.new(0, 220, 0, 280)
glowLayer.Position = UDim2.new(0.5, -110, 0.5, -140)
glowLayer.BackgroundTransparency = 1
glowLayer.Image = "rbxassetid://5028857084"
glowLayer.ImageColor3 = Color3.fromRGB(150, 0, 255)
glowLayer.ImageTransparency = 0.55
glowLayer.ScaleType = Enum.ScaleType.Slice
glowLayer.SliceCenter = Rect.new(24, 24, 276, 276)
glowLayer.ZIndex = 0

-- Mouse body
local mouseBody = Instance.new("Frame", screenGui)
mouseBody.Size = UDim2.new(0, 140, 0, 200)
mouseBody.Position = UDim2.new(0.5, -70, 0.5, -100)
mouseBody.BackgroundColor3 = Color3.fromRGB(14, 14, 17)
mouseBody.BorderSizePixel = 0
