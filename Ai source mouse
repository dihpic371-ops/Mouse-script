-- Button Factory
local function createButton(pos, size, mouseIdx, cornerRadius)
	local btn = Instance.new("TextButton", mouseBody)
	btn.Size = size
	btn.Position = pos
	btn.BackgroundColor3 = Color3.fromRGB(18, 18, 22)
	btn.BackgroundTransparency = 0.2
	btn.AutoButtonColor = false
	btn.Text = ""
	btn.ZIndex = 2

	local btnCorner = Instance.new("UICorner", btn)
	btnCorner.CornerRadius = cornerRadius

	local label = Instance.new("TextLabel", btn)
	label.Size = UDim2.new(1, 0, 1, 0)
	label.BackgroundTransparency = 1
	label.Text = mouseIdx == 0 and "L" or "R"
	label.Font = Enum.Font.GothamBlack
	label.TextSize = 18
	label.TextColor3 = Color3.fromRGB(180, 180, 195)
	label.TextTransparency = 0.2
	label.ZIndex = 3

	local btnStroke = Instance.new("UIStroke", btn)
	btnStroke.Thickness = 1
	btnStroke.Color = Color3.fromRGB(70, 70, 85)
	btnStroke.Transparency = 0.5

	btn.MouseEnter:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundTransparency = 0}):Play()
		TweenService:Create(btnStroke, TweenInfo.new(0.15), {Transparency = 0, Thickness = 1.5}):Play()
	end)
	btn.MouseLeave:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundTransparency = 0.2}):Play()
		TweenService:Create(btnStroke, TweenInfo.new(0.15), {Transparency = 0.5, Thickness = 1}):Play()
	end)

	-- Press: bright flash using current RGB hue + sink
	btn.MouseButton1Down:Connect(function()
		local flashColor = Color3.fromHSV((strokeGradient.Rotation / 360) % 1, 1, 1)
		TweenService:Create(btn, TweenInfo.new(0.06), {
			BackgroundColor3 = flashColor,
			BackgroundTransparency = 0,
		}):Play()
		TweenService:Create(label, TweenInfo.new(0.06), {TextColor3 = Color3.fromRGB(10, 10, 10), TextTransparency = 0}):Play()
		TweenService:Create(btnStroke, TweenInfo.new(0.06), {Color = flashColor, Transparency = 0, Thickness = 2}):Play()

		game:GetService("VirtualInputManager"):SendMouseButtonEvent(0, 0, mouseIdx, true, game, 1)
	end)

	btn.MouseButton1Up:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.18, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
			BackgroundColor3 = Color3.fromRGB(18, 18, 22),
			BackgroundTransparency = 0.2,
		}):Play()
		TweenService:Create(label, TweenInfo.new(0.18), {TextColor3 = Color3.fromRGB(180, 180, 195), TextTransparency = 0.2}):Play()
		TweenService:Create(btnStroke, TweenInfo.new(0.18), {Color = Color3.fromRGB(70, 70, 85), Transparency = 0.5, Thickness = 1}):Play()

		game:GetService("VirtualInputManager"):SendMouseButtonEvent(0, 0, mouseIdx, false, game, 1)
	end)

	return btn
end

local lBtn = createButton(UDim2.new(0, 6, 0, 6), UDim2.new(0, 60, 0, 76), 0, UDim.new(0, 34))
local rBtn = createButton(UDim2.new(0, 74, 0, 6), UDim2.new(0, 60, 0, 76), 1, UDim.new(0, 34))

