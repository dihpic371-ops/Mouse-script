local bodyCorner = Instance.new("UICorner", mouseBody)
bodyCorner.CornerRadius = UDim.new(0, 45)

local bodyGradient = Instance.new("UIGradient", mouseBody)
bodyGradient.Color = ColorSequence.new({
	ColorSequenceKeypoint.new(0, Color3.fromRGB(24, 24, 28)),
	ColorSequenceKeypoint.new(0.5, Color3.fromRGB(14, 14, 17)),
	ColorSequenceKeypoint.new(1, Color3.fromRGB(8, 8, 10)),
})
bodyGradient.Rotation = 90

-- RGB rainbow outline (cycles hue continuously)
local stroke = Instance.new("UIStroke", mouseBody)
stroke.Thickness = 2.5
stroke.Transparency = 0
stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

local strokeGradient = Instance.new("UIGradient", stroke)
strokeGradient.Color = ColorSequence.new({
	ColorSequenceKeypoint.new(0, Color3.fromHSV(0, 1, 1)),
	ColorSequenceKeypoint.new(0.17, Color3.fromHSV(0.17, 1, 1)),
	ColorSequenceKeypoint.new(0.33, Color3.fromHSV(0.33, 1, 1)),
	ColorSequenceKeypoint.new(0.5, Color3.fromHSV(0.5, 1, 1)),
	ColorSequenceKeypoint.new(0.67, Color3.fromHSV(0.67, 1, 1)),
	ColorSequenceKeypoint.new(0.83, Color3.fromHSV(0.83, 1, 1)),
	ColorSequenceKeypoint.new(1, Color3.fromHSV(1, 1, 1)),
})

-- Sync glow layer color + rotate stroke gradient together
task.spawn(function()
	local hue = 0
	while mouseBody.Parent do
		hue = (hue + 0.004) % 1
		strokeGradient.Rotation = (strokeGradient.Rotation + 3) % 360
		glowLayer.ImageColor3 = Color3.fromHSV(hue, 1, 1)
		task.wait(0.03)
	end
end)

-- Pulsing glow intensity (breathing effect)
local glowPulse = TweenService:Create(glowLayer, TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), {ImageTransparency = 0.75})
glowPulse:Play()

